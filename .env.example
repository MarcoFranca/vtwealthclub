# Sanity — crie um projeto gratuito em https://www.sanity.io/manage e cole os valores aqui.
# Enquanto estas variáveis não existirem, o site funciona normalmente usando o conteúdo
# local em src/sanity/data (ver src/sanity/env.ts -> isSanityConfigured).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# SMTP — use a conta de e-mail já hospedada no cPanel/RapidCloud
# (cPanel > Email Accounts > [conta] > Connect Devices, mostra host/porta/usuário).
# Sem estas variáveis, os formulários de Contato e Cotação retornam erro amigável
# em vez de enviar e-mail.
SMTP_HOST=mail.vtwealthclub.com.br
SMTP_PORT=465
SMTP_USER=contato@vtwealthclub.com.br
SMTP_PASSWORD=
# Opcionais — por padrão usam o próprio SMTP_USER
SMTP_FROM_EMAIL=contato@vtwealthclub.com.br
SMTP_TO_EMAIL=contato@vtwealthclub.com.br
